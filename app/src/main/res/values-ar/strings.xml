    <!-- ═══════════════════════════════════════════════════════════════
         Font List Count Strings — عدد الخطوط في عنوان CollapsingToolbar
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ★ الإصلاح (المشكلة 5): نظام الجمع العربي عبر <plurals> ★
         يحل محل font_list_count_single/multiple/none ذات المنطق البدائي.

         قواعد الجمع العربي في Android:
           zero  → 0                  : لا توجد خطوط
           one   → 1                  : خط واحد
           two   → 2                  : خطين
           few   → 3-10               : %d خطوط   (جمع قلة)
           many  → 11-99, 101-109...  : %d خط     (جمع كثرة)
           other → الكسور وما تبقى    : %d خط

         الاستخدام في Java (MainActivity):
           getResources().getQuantityString(R.plurals.font_list_count, count, count)

         ملاحظة: الـ strings القديمة (single/multiple/none) محتفظ بها مؤقتاً
         للتوافق حتى يتم تحديث MainActivity لاستخدام getQuantityString(). -->
    <plurals name="font_list_count">
        <item quantity="zero">لا توجد خطوط</item>
        <item quantity="one">خط واحد</item>
        <item quantity="two">خطين</item>
        <item quantity="few">%d خطوط</item>
        <item quantity="many">%d خط</item>
        <item quantity="other">%d خط</item>
    </plurals>

