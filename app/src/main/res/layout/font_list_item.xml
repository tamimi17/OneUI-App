<?xml version="1.0" encoding="utf-8"?>
<!--
    ★ التعديل: إضافة أيقونة المفضلة (ic_favorite) ★
    - تُضاف ImageView بمعرّف font_item_favorite_icon في نهاية الـ LinearLayout الأفقي
    - الأيقونة: ic_favorite (أيقونة قلب صفراء تُشير إلى كون الخط مفضلاً)
    - تُخفى بالكامل (GONE) للخطوط غير المفضلة لكي لا تشغل مساحة
    - تُظهَر (VISIBLE) تلقائياً للخطوط المفضلة عبر LocalFontViewHolder.bind()
-->
<dev.oneuiproject.oneui.widget.RoundLinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/oui_background_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/font_list_ripple"
        android:animateLayoutChanges="true"
        android:paddingHorizontal="28dp"
        android:paddingVertical="19dp">

        <!-- CheckBox للتحديد المتعدد — يظهر فقط في وضع الاختيار -->
        <CheckBox
            android:id="@+id/checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="?android:listPreferredItemPaddingStart"
            android:background="@null"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone" />

        <!-- ★ LinearLayout عمودي يحتوي اسم الخط + وصف الوزن/العرض
             layout_weight="1" يملأ المساحة المتبقية ويدفع أيقونة المفضلة لليمين ★ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- اسم الخط — يدعم تظليل نص البحث -->
            <TextView
                android:id="@+id/font_item_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:padding="-10dp"
                android:layout_marginBottom="7sp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorPrimary"
                android:fontFamily="sec-bold"
                tools:text="Font Name Example" />

            <!-- ★ وصف الوزن والعرض — باللون الثانوي ★
                 أمثلة: "Bold, Condensed" | "VF · Regular" | "غير معروف" -->
            <TextView
                android:id="@+id/font_item_weight_width"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textSize="13sp"
                android:textColor="@color/sesl_secondary_text_color"
                tools:text="Bold, Condensed" />

        </LinearLayout>

        <!-- ★ أيقونة المفضلة — تُظهر للخطوط المفضلة فقط ★
             الأيقونة: ic_favorite (قلب صفراء)
             القيمة الافتراضية: GONE (مخفية لتوفير المساحة)
             يُظهرها LocalFontViewHolder.bind() عند isFavorite = true -->
        <ImageView
            android:id="@+id/font_item_favorite_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="12dp"
            android:contentDescription="@string/action_add_favorite"
            android:src="@drawable/ic_favorite"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

    <View
        android:id="@+id/item_divider"
        android:layout_height="1dp"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:background="@color/oui_list_divider_color" />

</dev.oneuiproject.oneui.widget.RoundLinearLayout>
