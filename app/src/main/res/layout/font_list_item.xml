<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.widget.RoundLinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/oui_background_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/font_list_ripple"
        android:gravity="center_vertical"
        android:animateLayoutChanges="true">

        <CheckBox
            android:id="@+id/checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="?android:listPreferredItemPaddingStart"
            android:layout_marginStart="?android:listPreferredItemPaddingStart"
            android:background="@null"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone" />

        <!-- حاوية عمودية إضافية للنصوص -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"	
            android:orientation="vertical">

            <!-- اسم الخط داخل LinearLayout مستقل -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="30sp"
                android:paddingHorizontal="28dp"
                android:paddingTop="12dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/font_item_name"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:fontFamily="sec-bold"
                    tools:text="Font Name Example" />
            </LinearLayout>

            <!-- الوزن/العرض داخل LinearLayout مستقل -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:paddingHorizontal="28dp"
                android:paddingBottom="12dp"
                android:layout_height="25sp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/font_item_weight_width"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    tools:text="Bold, Condensed" />
                    
            </LinearLayout>  
           
            <LinearLayout  
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:orientation="vertical">
            	
                <View
                    android:id="@+id/item_divider"
                    android:layout_height="1dp"
                    android:layout_width="match_parent"
                    android:background="@color/oui_list_divider_color" />
             
            </LinearLayout>
            
        </LinearLayout>
            
    </LinearLayout>

</dev.oneuiproject.oneui.widget.RoundLinearLayout>
