<?xml version="1.0" encoding="utf-8"?>
<!--
    ★ التعديل: إعادة هيكلة الـ LinearLayout الداخلي لدعم سطرَين ★
    - الارتفاع: من 70dp ثابت إلى wrap_content مع minHeight="70dp"
    - تم تضمين paddingVertical="12dp" لمنح الفراغ الكافي للسطرَين
    - اسم الخط ووصف الوزن/العرض داخل LinearLayout عمودي موزون
-->
<dev.oneuiproject.oneui.widget.RoundLinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/oui_background_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/font_list_ripple"
        android:animateLayoutChanges="true"
        android:paddingHorizontal="28dp"
        android:paddingVertical="9dp">

        <!-- CheckBox للتحديد المتعدد — يظهر فقط في وضع الاختيار -->
        <CheckBox
            android:id="@+id/checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="?android:listPreferredItemPaddingStart"
            android:background="@null"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone" />

        <!-- ★ LinearLayout عمودي يحتوي اسم الخط + وصف الوزن/العرض ★ -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- اسم الخط — يدعم تظليل نص البحث -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/font_item_name"
                android:layout_width="wrap_content"
                android:layout_height="25sp"
                android:includeFontPadding="false"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="16sp"
                android:textColor="?android:attr/textColorPrimary"
                android:fontFamily="sec-bold"
                tools:text="Font Name Example" />

            <!-- ★ وصف الوزن والعرض — باللون الثانوي ★
                 أمثلة: "Bold, Condensed" | "VF · Regular" | "غير معروف" -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/font_item_weight_width"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                tools:text="Bold, Condensed" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/item_divider"
        android:layout_height="1dp"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:background="@color/oui_list_divider_color" />

</dev.oneuiproject.oneui.widget.RoundLinearLayout>
