<?xml version="1.0" encoding="utf-8"?>
<!--
    ★ الإصلاح: تغيير الجذر من RelativeLayout إلى FrameLayout ★

    أسباب التغيير:
    1. (المشكلة 2) RelativeLayout مع layout_height="match_parent" + layout_above
       يُعطي نتائج غير محددة عند تمدد CollapsingToolbar، مما يُسبب اختفاء
       الشريط السفلي لأن المقياسين يتعارضان أثناء التحريك.
    2. (المشكلة 3) الفراغ الناتج بين NestedScrollView والشاشة كان يُظهر خلفية
       RelativeLayout الداكنة خلف زوايا الـ CardView المستديرة في الوضع الداكن.

    الحل المعتمد:
    - NestedScrollView يملأ match_parent مع clipToPadding="false" و paddingBottom
      لضمان تمرير المحتوى كاملاً فوق الشريط دون فراغ مكشوف خلفه.

    ★ التعديل الجديد: حُذف CardView (bottom_formatting_bar) من هذا الملف ★
    انتقل الشريط إلى bottom_formatting_bar.xml ويُدرج في activity_main.xml عبر
    <include app:layout_location="root"> ليُثبَّت في الطبقة الجذرية لـ DrawerLayout
    بعيداً عن تأثير CollapsingToolbar. تُدار رؤيته من MainActivity لا من Fragment.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--
        ★ الـ NestedScrollView يملأ الشاشة بالكامل ★
        layout_marginBottom="88dp" يُفسح مساحة أسفل الـ ScrollView تساوي ارتفاع
        الشريط العائم، مما يمنع آخر المحتوى من الاختباء خلفه عند التمرير للنهاية.
        هذا النهج مطابق لأسلوب FloatingActionBar في مكتبة OneUI، ويعمل لأن
        main_content في DrawerLayout ثابت الارتفاع ولا يتأثر بتمدد CollapsingToolbar.
    -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/font_viewer_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="88dp"
        android:overScrollMode="always"
        android:scrollbars="vertical"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <dev.oneuiproject.oneui.widget.RoundLinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="27dp"
                android:background="@color/oui_background_color"
                android:orientation="vertical">

                <!--
                    ★ حاوية معلومات الوزن — في أعلى العارض ★
                    تُعرض هنا نتيجةً واحدة فقط في أي وقت:
                      • weight_label_text : نص ثابت للخطوط غير المتغيرة (مثل "Bold, Condensed")
                      • weight_spinner    : منتقي تفاعلي للخطوط المتغيرة (Variable Fonts)
                    كلاهما يبدأ مخفياً (gone) ويُظهره FontViewerFragment بعد تحميل الخط.
                -->

                <!-- وصف الوزن والعرض للخطوط الثابتة -->
                <TextView
                    android:id="@+id/weight_label_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="17sp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone" />

                <!-- منتقي الوزن للخطوط المتغيرة -->
                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/weight_spinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone" />

                <!-- معاينة النص -->
                <TextView
                    android:id="@+id/preview_sentence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="7dp"
                    android:textSize="18sp"
                    android:textColor="@color/oui_primary_text_color" />

            </dev.oneuiproject.oneui.widget.RoundLinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!--
        ★ شريط أدوات التنسيق العائم — ثابت في أسفل الشاشة دائماً ★

        يطفو فوق NestedScrollView عبر layout_gravity="bottom" في FrameLayout.
        يبقى ثابتاً لأن main_content في DrawerLayout لا يُعاد قياسه عند تمدد
        CollapsingToolbar — تماماً كما يعمل FloatingActionBar في مكتبة OneUI.

        استخدام CardView بدلاً من BottomNavigationView هو الخيار الصحيح معمارياً؛
        لأن هذا شريط تنسيق (Formatting Toolbar) وليس شريط تنقل (Navigation).
        مظهره العائم مشابه لواجهات سامسونج الأصلية (مثل تطبيق Samsung Notes).
    -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottom_formatting_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="?attr/colorBackgroundFloating">

        <!--
            ★ توزيع الأيقونات بالتساوي عبر layout_weight ★
            كل زر يحصل على layout_weight="1" ليحتل ثلث العرض بالضبط،
            مع layout_width="0dp" لتفعيل توزيع الأوزان بشكل صحيح.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical">

            <!--
                زر تغيير حجم الخط — يفتح FontSizeDialog (منقول من الـ FAB)
                layout_weight="1" يمنحه ثلث عرض الشريط لضمان التوزيع المتساوي.
                scaleType="center" يُثبّت حجم الأيقونة الأصلي داخل المساحة الموسّعة.
            -->
            <ImageView
                android:id="@+id/btn_font_size"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:scaleType="center"
                android:background="@drawable/sort_btn_ripple"
                android:src="@drawable/ic_oui_font_size"
                android:contentDescription="@string/font_size_and_style" />

            <!--
                زر الخط العريض (Bold) — يتمتع بحالة تبديل مُميَّزة
                bg_format_toggle يُغيّر لون الخلفية عند setSelected(true).
                layout_weight="1" يمنحه ثلث عرض الشريط.
            -->
            <ImageView
                android:id="@+id/btn_font_bold"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:scaleType="center"
                android:background="@drawable/bg_format_toggle"
                android:src="@drawable/ic_oui_text_bold"
                android:contentDescription="@string/font_bold" />

            <!--
                زر الخط المائل (Italic) — يتمتع بحالة تبديل مُميَّزة
                bg_format_toggle يُغيّر لون الخلفية عند setSelected(true).
                layout_weight="1" يمنحه ثلث عرض الشريط.
            -->
            <ImageView
                android:id="@+id/btn_font_italic"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:scaleType="center"
                android:background="@drawable/bg_format_toggle"
                android:src="@drawable/ic_oui_text_italic"
                android:contentDescription="@string/font_italic" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>
