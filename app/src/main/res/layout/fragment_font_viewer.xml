<?xml version="1.0" encoding="utf-8"?>
<!--
    ★ تغليف المحتوى بـ RelativeLayout لتثبيت شريط التنسيق السفلي ★
    هذا يضمن أن الـ CardView ملتصق بأسفل الشاشة دائماً،
    معزولاً تماماً عن حركة الـ Scroll والـ CollapsingToolbar.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--
        ★ الـ NestedScrollView مقيّد من الأسفل بالشريط السفلي ★
        layout_above يمنع المحتوى من الاختباء خلف الشريط.
    -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/font_viewer_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_formatting_bar"
        android:overScrollMode="always"
        android:scrollbars="vertical"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <dev.oneuiproject.oneui.widget.RoundLinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="27dp"
                android:background="@color/oui_background_color"
                android:orientation="vertical">

                <!--
                    ★ حاوية معلومات الوزن — في أعلى العارض ★
                    تُعرض هنا نتيجةً واحدة فقط في أي وقت:
                      • weight_label_text : نص ثابت للخطوط غير المتغيرة (مثل "Bold, Condensed")
                      • weight_spinner    : منتقي تفاعلي للخطوط المتغيرة (Variable Fonts)
                    كلاهما يبدأ مخفياً (gone) ويُظهره FontViewerFragment بعد تحميل الخط.
                -->

                <!-- وصف الوزن والعرض للخطوط الثابتة -->
                <TextView
                    android:id="@+id/weight_label_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="17sp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone" />

                <!-- منتقي الوزن للخطوط المتغيرة -->
                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/weight_spinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone" />

                <!-- معاينة النص -->
                <TextView
                    android:id="@+id/preview_sentence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="7dp"
                    android:textSize="18sp"
                    android:textColor="@color/oui_primary_text_color" />

            </dev.oneuiproject.oneui.widget.RoundLinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!--
        ★ شريط أدوات التنسيق العائم — ثابت في أسفل الشاشة دائماً ★
        استخدام CardView بدلاً من BottomNavigationView هو الخيار الصحيح معمارياً؛
        لأن هذا شريط تنسيق (Formatting Toolbar) وليس شريط تنقل (Navigation).
        layout_alignParentBottom + layout_centerHorizontal يمنحانه مظهراً عائماً
        مشابهاً لواجهات سامسونج الأصلية (مثل تطبيق Samsung Notes).
    -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottom_formatting_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_location="root"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="?attr/colorBackgroundFloating">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center">

            <!--
                زر تغيير حجم الخط — يفتح FontSizeDialog (منقول من الـ FAB)
                يستخدم selectableItemBackgroundBorderless للتموجات الدائرية.
            -->
            <ImageView
                android:id="@+id/btn_font_size"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_oui_font_size"
                android:contentDescription="@string/font_size_and_style" />

            <!--
                زر الخط العريض (Bold) — يتمتع بحالة تبديل مُميَّزة
                bg_format_toggle يُغيّر لون الخلفية عند setSelected(true).
            -->
            <ImageView
                android:id="@+id/btn_font_bold"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:padding="12dp"
                android:background="@drawable/bg_format_toggle"
                android:src="@drawable/ic_oui_text_bold"
                android:contentDescription="@string/font_bold" />

            <!--
                زر الخط المائل (Italic) — يتمتع بحالة تبديل مُميَّزة
                bg_format_toggle يُغيّر لون الخلفية عند setSelected(true).
            -->
            <ImageView
                android:id="@+id/btn_font_italic"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:padding="12dp"
                android:background="@drawable/bg_format_toggle"
                android:src="@drawable/ic_oui_text_italic"
                android:contentDescription="@string/font_italic" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>
