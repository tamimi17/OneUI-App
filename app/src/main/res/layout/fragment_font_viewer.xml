<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Scrollable content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/font_viewer_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="always"
            android:scrollbars="vertical"
            android:fillViewport="true"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingBottom="120dp">

                <dev.oneuiproject.oneui.widget.RoundLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="27dp"
                    android:background="@color/oui_background_color"
                    android:orientation="vertical">

                    <!-- وصف الوزن للخطوط الثابتة -->
                    <TextView
                        android:id="@+id/weight_label_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="17sp"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone" />

                    <!-- منتقي الوزن للخطوط المتغيرة -->
                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/weight_spinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone" />

                    <!-- معاينة النص -->
                    <TextView
                        android:id="@+id/preview_sentence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="7dp"
                        android:textSize="18sp"
                        android:textColor="@color/oui_primary_text_color" />

                </dev.oneuiproject.oneui.widget.RoundLinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- شريط الأدوات العائم -->
        <androidx.cardview.widget.CardView
            android:id="@+id/bottom_formatting_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="?attr/colorBackgroundFloating">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btn_font_size"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:scaleType="center"
                    android:background="@drawable/sort_btn_ripple"
                    android:src="@drawable/ic_oui_font_size"
                    android:contentDescription="@string/font_size_and_style" />

                <ImageView
                    android:id="@+id/btn_font_bold"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:scaleType="center"
                    android:background="@drawable/bg_format_toggle"
                    android:src="@drawable/ic_oui_text_bold"
                    android:contentDescription="@string/font_bold" />

                <ImageView
                    android:id="@+id/btn_font_italic"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:padding="12dp"
                    android:scaleType="center"
                    android:background="@drawable/bg_format_toggle"
                    android:src="@drawable/ic_oui_text_italic"
                    android:contentDescription="@string/font_italic" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </FrameLayout>

</dev.oneuiproject.oneui.layout.ToolbarLayout>
