<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/font_viewer_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="always"
        android:scrollbars="vertical"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingBottom="104dp">

            <dev.oneuiproject.oneui.widget.RoundLinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="27dp"
                android:background="@color/oui_background_color"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/btn_font_bold"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:scaleType="center"
                        android:background="@drawable/bg_format_toggle"
                        android:src="@drawable/ic_oui_text_bold"
                        android:contentDescription="@string/font_bold" />

                    <ImageView
                        android:id="@+id/btn_font_italic"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:scaleType="center"
                        android:background="@drawable/bg_format_toggle"
                        android:src="@drawable/ic_oui_text_italic"
                        android:contentDescription="@string/font_italic" />

                </LinearLayout>

                <!-- وصف الوزن والعرض للخطوط الثابتة -->
                <TextView
                    android:id="@+id/weight_label_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="17sp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <!-- منتقي الوزن للخطوط المتغيرة -->
                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/weight_spinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <!-- معاينة النص -->
                <TextView
                    android:id="@+id/preview_sentence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="7dp"
                    android:textSize="18sp"
                    android:textColor="@color/oui_primary_text_color" />

            </dev.oneuiproject.oneui.widget.RoundLinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>
