<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/font_viewer_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="always"
    android:scrollbars="vertical"
    android:fillViewport="true">
       
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="104dp">

        <dev.oneuiproject.oneui.widget.RoundLinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="27dp"
            android:background="@color/oui_background_color"
            android:orientation="vertical">

            <!--
                ★ حاوية معلومات الوزن — في أعلى العارض ★
                تُعرض هنا نتيجةً واحدة فقط في أي وقت:
                  • weight_label_text : نص ثابت للخطوط غير المتغيرة (مثل "Bold, Condensed")
                  • weight_spinner    : منتقي تفاعلي للخطوط المتغيرة (Variable Fonts)
                كلاهما يبدأ مخفياً (gone) ويُظهره FontViewerFragment بعد تحميل الخط.
            -->

            <!-- وصف الوزن والعرض للخطوط الثابتة -->
            <TextView
                android:id="@+id/weight_label_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="17sp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- منتقي الوزن للخطوط المتغيرة -->
            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/weight_spinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- معاينة النص -->
            <!-- حاوية المعاينة مع مسافة جانبية لاستيعاب الحروف المائلة -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="6dp"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/preview_sentence"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingExtra="7dp"
                    android:textSize="18sp"
                    android:textColor="@color/oui_primary_text_color" />

                <View
                    android:layout_width="6dp"
                    android:layout_height="match_parent" />

            </LinearLayout>
        
        </dev.oneuiproject.oneui.widget.RoundLinearLayout>
        
    </LinearLayout>
    
</androidx.core.widget.NestedScrollView>
